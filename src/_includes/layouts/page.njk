---
layout: layouts/base.njk
---

{% block content %}
  <article class="page">
    <header class="page-header stack">
      <h1>{{ title }}</h1>
      {% if description %}
        <p class="page-description">{{ description }}</p>
      {% endif %}
    </header>
    <div class="page-body stack">
      {{ content | safe }}
    </div>
  </article>
{% endblock %}
