<header class="site-header">
  <div class="site-header-inner cluster">
    <div class="cluster">
      <a href="{{ '/' | url }}" class="site-title">
        <img
          src="/assets/img/Site%20icon/Bumblefucks_Unite_D&amp;D.jpg"
          alt="Bumble Fucks Unite D&D logo"
          class="site-logo"
        />
        <span>{{ site.title }}</span>
      </a>
    </div>

    <nav class="site-nav" aria-label="Primary">
      <ul class="cluster site-nav-list">
        {% for item in nav.sections %}
          {% if item.url != "/" %}
            <li>
              <a
                href="{{ item.url | url }}"
                class="site-nav-link{% if page.url == item.url %} is-active{% endif %}"
                {% if page.url == item.url %}aria-current="page"{% endif %}
              >
                {{ item.title }}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>
